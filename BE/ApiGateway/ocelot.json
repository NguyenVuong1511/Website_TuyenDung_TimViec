{
  "Routes": [
    // 1.IdentityService (Đăng ký, Đăng nhập)
    {
      "DownstreamPathTemplate": "/api/auth/{catchAll}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7201
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{catchAll}",
      "UpstreamHttpMethod": [
        "Post"
      ]
    },
    // 2.Categories (Ngành nghề)
    {
      "DownstreamPathTemplate": "/api/categories",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7004
        }
      ],
      "UpstreamPathTemplate": "/gateway/categories",
      "UpstreamHttpMethod": [
        "Get"
      ]
    },
    // 3.Companies (Danh sách công ty)
    {
      "DownstreamPathTemplate": "/api/companies",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7004
        }
      ],
      "UpstreamPathTemplate": "/gateway/companies",
      "UpstreamHttpMethod": [
        "Get"
      ]
    },
    // 4.JobPosts (Danh sách bài đăng)
    {
      "DownstreamPathTemplate": "/api/jobposts",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7004
        }
      ],
      "UpstreamPathTemplate": "/gateway/jobposts",
      "UpstreamHttpMethod": [
        "Get"
      ]
    },
    {
      "DownstreamPathTemplate": "/api/jobposts/top",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7004
        }
      ],
      "UpstreamPathTemplate": "/gateway/jobposts/top",
      "UpstreamHttpMethod": [
        "Get"
      ]
    },
    // 5.JobService 
    {
      "DownstreamPathTemplate": "/{catchAll}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7004
        }
      ],
      "UpstreamPathTemplate": "/gateway/{catchAll}",
      "UpstreamHttpMethod": [
        "Get",
        "Post",
        "Put",
        "Delete"
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7255"
  }
}